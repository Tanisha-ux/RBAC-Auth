<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Join Ledgerly — Create your account</title>

<!-- Google Fonts: Fraunces (display/serif), Inter (body/UI), JetBrains Mono (labels/data) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<!--
  Served by express.static("public"), so this file expects to live at:
  public/css/signup.css
-->
<link rel="stylesheet" href="/signup.css">
</head>
<body>

<div class="shell">

  <!-- ============================ -->
  <!-- LEFT: brand / narrative panel -->
  <!-- ============================ -->
  <div class="brand-panel">
    <div class="brand-mark"><span class="dot"></span> Ledgerly</div>

    <div class="brand-copy">
      <h1>Build something <em>people return to.</em></h1>
      <p>Ledgerly gives small teams the bookkeeping clarity usually reserved for companies ten times their size. Set up takes four fields and two minutes.</p>
    </div>

    <!-- Signature element: a live rail that fills in as the form is completed -->
    <div class="progress-rail" id="progressRail">
      <div class="rail-item" data-rail="name"><span class="rail-marker"></span> 01 — Full name</div>
      <div class="rail-item" data-rail="email"><span class="rail-marker"></span> 02 — Email</div>
      <div class="rail-item" data-rail="password"><span class="rail-marker"></span> 03 — Password</div>
      <div class="rail-item" data-rail="confirmPassword"><span class="rail-marker"></span> 04 — Confirmation</div>
    </div>
  </div>

  <!-- ============================ -->
  <!-- RIGHT: form panel             -->
  <!-- ============================ -->
  <div class="form-panel">
    <div class="form-wrap">

      <!-- ---- Sign-up form (visible by default) ---- -->
      <form id="signupForm" novalidate>
        <div class="eyebrow">Create account</div>
        <h2>Set up your workspace</h2>
        <p class="lede">Already have one? <a href="http://localhost:3001/login">Log in instead.</a></p>

        <!-- Server-level error banner (e.g. duplicate email, 500 error) -->
        <div class="form-error-banner" id="formErrorBanner"></div>

        <!-- Name field -->
        <div class="field" id="nameField">
          <input type="text" id="name" name="name" placeholder="Full name" autocomplete="name" />
          <label for="name">Full name</label>
          <svg class="status-icon icon-valid" viewBox="0 0 18 18" fill="none"><path d="M3 9.5L7 13L15 5" stroke="#4E8B6B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <svg class="status-icon icon-invalid" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7.3" stroke="#C04A3F" stroke-width="1.4"/><path d="M9 5.5V9.8" stroke="#C04A3F" stroke-width="1.4" stroke-linecap="round"/><circle cx="9" cy="12.4" r="0.9" fill="#C04A3F"/></svg>
          <div class="error-text" id="nameError"></div>
        </div>

        <!-- Email field -->
        <div class="field" id="emailField">
          <input type="text" id="email" name="email" placeholder="Email address" autocomplete="email" />
          <label for="email">Email address</label>
          <svg class="status-icon icon-valid" viewBox="0 0 18 18" fill="none"><path d="M3 9.5L7 13L15 5" stroke="#4E8B6B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <svg class="status-icon icon-invalid" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7.3" stroke="#C04A3F" stroke-width="1.4"/><path d="M9 5.5V9.8" stroke="#C04A3F" stroke-width="1.4" stroke-linecap="round"/><circle cx="9" cy="12.4" r="0.9" fill="#C04A3F"/></svg>
          <div class="error-text" id="emailError"></div>
        </div>

        <!-- Password field -->
        <div class="field has-toggle" id="passwordField">
          <input type="password" id="password" name="password" placeholder="Password" autocomplete="new-password" />
          <label for="password">Password</label>
          <button type="button" class="toggle-visibility" id="togglePassword" aria-label="Show password">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M1.5 10S4.5 4 10 4s8.5 6 8.5 6-3 6-8.5 6-8.5-6-8.5-6Z" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="10" r="2.4" stroke="currentColor" stroke-width="1.4"/></svg>
          </button>
          <div class="strength-meter" id="strengthMeter">
            <div class="seg"></div><div class="seg"></div><div class="seg"></div><div class="seg"></div>
          </div>
          <div class="strength-label" id="strengthLabel">&nbsp;</div>
          <div class="error-text" id="passwordError"></div>
        </div>

        <!-- Confirm password field (frontend-only check — not sent to the server) -->
        <div class="field has-toggle" id="confirmPasswordField">
          <input type="password" id="confirmPassword" placeholder="Confirm password" autocomplete="new-password" />
          <label for="confirmPassword">Confirm password</label>
          <button type="button" class="toggle-visibility" id="toggleConfirmPassword" aria-label="Show password">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M1.5 10S4.5 4 10 4s8.5 6 8.5 6-3 6-8.5 6-8.5-6-8.5-6Z" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="10" r="2.4" stroke="currentColor" stroke-width="1.4"/></svg>
          </button>
          <div class="error-text" id="confirmPasswordError"></div>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn" >Create account</button>

        <p class="fine-print">By continuing you agree to Ledgerly's <a href="#">Terms</a> and <a href="#">Privacy Policy</a>.</p>
      </form>

      <!-- ---- Success state (hidden until the server confirms signup) ---- -->
      <div class="success-state" id="successState">
        <div class="mark">
          <svg width="22" height="22" viewBox="0 0 18 18" fill="none"><path d="M3 9.5L7 13L15 5" stroke="#4E8B6B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h2>You're in.</h2>
        <p id="successCopy">Account created — redirecting you to your workspace shortly.</p>
      </div>

    </div>
  </div>

</div>

<script>
/* ============================================================ */
/* signup.ejs — inline script: validation + API call             */
/* Talks to the existing Express backend:                        */
/*   POST /users/signup  { name, email, password }               */
/*   -> 201 { newUser: {id,name,email}, msg }                    */
/*   -> 400 { msg }   (missing fields)                            */
/*   -> 500 { msg }   (server / db error)                        */
/* ============================================================ */

const form = document.getElementById('signupForm');

const nameInput = document.getElementById('name');
const emailInput = document.getElementById('email');
const passwordInput = document.getElementById('password');
const confirmPasswordInput = document.getElementById('confirmPassword');

const nameField = document.getElementById('nameField');
const emailField = document.getElementById('emailField');
const passwordField = document.getElementById('passwordField');
const confirmPasswordField = document.getElementById('confirmPasswordField');

const nameError = document.getElementById('nameError');
const emailError = document.getElementById('emailError');
const passwordError = document.getElementById('passwordError');
const confirmPasswordError = document.getElementById('confirmPasswordError');

const strengthMeter = document.getElementById('strengthMeter');
const strengthLabel = document.getElementById('strengthLabel');
const strengthSegs = strengthMeter.querySelectorAll('.seg');

const successState = document.getElementById('successState');
const submitBtn = document.getElementById('submitBtn');
const formErrorBanner = document.getElementById('formErrorBanner');

// ---- Helpers: mark a field valid / invalid / neutral ----
function markValid(field, errorEl) {
  field.classList.remove('is-invalid');
  field.classList.add('is-valid');
  errorEl.textContent = '';
}

function markInvalid(field, errorEl, message) {
  field.classList.remove('is-valid');
  field.classList.add('is-invalid');
  errorEl.textContent = message;
}

function markNeutral(field, errorEl) {
  field.classList.remove('is-valid', 'is-invalid');
  errorEl.textContent = '';
}

function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

// ---- Field-level validators (mirror the backend's required-field check,
// plus the extras — email format, length, match — that the backend doesn't do) ----
function validateName(showEmptyError) {
  const value = nameInput.value.trim();
  if (value === '') {
    if (showEmptyError) markInvalid(nameField, nameError, 'Enter your full name.');
    else markNeutral(nameField, nameError);
    return false;
  }
  markValid(nameField, nameError);
  return true;
}

function validateEmail(showEmptyError) {
  const value = emailInput.value.trim();
  if (value === '') {
    if (showEmptyError) markInvalid(emailField, emailError, 'Enter your email address.');
    else markNeutral(emailField, emailError);
    return false;
  }
  if (!isValidEmail(value)) {
    markInvalid(emailField, emailError, 'That email address looks incomplete.');
    return false;
  }
  markValid(emailField, emailError);
  return true;
}

function validatePassword(showEmptyError) {
  const value = passwordInput.value;
  if (value === '') {
    if (showEmptyError) markInvalid(passwordField, passwordError, 'Choose a password.');
    else markNeutral(passwordField, passwordError);
    return false;
  }
  if (value.length < 6) {
    markInvalid(passwordField, passwordError, 'Use at least 6 characters.');
    return false;
  }
  markValid(passwordField, passwordError);
  return true;
}

function validateConfirmPassword(showEmptyError) {
  const value = confirmPasswordInput.value;
  if (value === '') {
    if (showEmptyError) markInvalid(confirmPasswordField, confirmPasswordError, 'Confirm your password.');
    else markNeutral(confirmPasswordField, confirmPasswordError);
    return false;
  }
  if (value !== passwordInput.value) {
    markInvalid(confirmPasswordField, confirmPasswordError, 'Passwords do not match.');
    return false;
  }
  markValid(confirmPasswordField, confirmPasswordError);
  return true;
}

// ---- Password strength meter ----
function getPasswordStrength(value) {
  let score = 0;
  if (value.length >= 6) score++;
  if (/[a-z]/.test(value) && /[A-Z]/.test(value)) score++;
  if (/[0-9]/.test(value)) score++;
  if (/[^A-Za-z0-9]/.test(value)) score++;
  return score;
}

const strengthColors = ['#C04A3F', '#C99A3B', '#C99A3B', '#4E8B6B'];
const strengthLabels = ['Weak', 'Fair', 'Good', 'Strong'];

function updateStrengthMeter() {
  const value = passwordInput.value;
  if (value === '') {
    strengthSegs.forEach(seg => seg.style.background = '');
    strengthLabel.textContent = '\u00A0';
    return;
  }
  const score = getPasswordStrength(value);
  const filledCount = Math.max(score, 1);
  strengthSegs.forEach((seg, index) => {
    seg.style.background = index < filledCount ? strengthColors[score - 1] || strengthColors[0] : '';
  });
  strengthLabel.textContent = strengthLabels[score - 1] || strengthLabels[0];
}

// ---- Progress rail (left panel) ----
function updateRail(stepId, isComplete) {
  const railItem = document.querySelector('[data-rail="' + stepId + '"]');
  if (!railItem) return;
  railItem.classList.toggle('done', isComplete);
}

// ---- Show / hide password toggles ----
function wireVisibilityToggle(buttonId, inputEl) {
  const button = document.getElementById(buttonId);
  button.addEventListener('click', function () {
    const isPassword = inputEl.type === 'password';
    inputEl.type = isPassword ? 'text' : 'password';
    button.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
  });
}
wireVisibilityToggle('togglePassword', passwordInput);
wireVisibilityToggle('toggleConfirmPassword', confirmPasswordInput);

// ---- Live validation as the user types ----
nameInput.addEventListener('input', () => updateRail('name', validateName(false)));
emailInput.addEventListener('input', () => updateRail('email', validateEmail(false)));
passwordInput.addEventListener('input', function () {
  updateStrengthMeter();
  updateRail('password', validatePassword(false));
  if (confirmPasswordInput.value !== '') {
    updateRail('confirmPassword', validateConfirmPassword(false));
  }
});
confirmPasswordInput.addEventListener('input', () => updateRail('confirmPassword', validateConfirmPassword(false)));

// ---- Server error banner helper ----
function showServerError(message) {
  formErrorBanner.textContent = message;
  formErrorBanner.style.display = 'block';
}

function hideServerError() {
  formErrorBanner.style.display = 'none';
  formErrorBanner.textContent = '';
}

// ---- Submit: validate locally, then call the real API ----
form.addEventListener('submit', async function (event) {
  event.preventDefault();
  hideServerError();

  const nameOk = validateName(true);
  const emailOk = validateEmail(true);
  const passwordOk = validatePassword(true);
  const confirmOk = validateConfirmPassword(true);

  updateRail('name', nameOk);
  updateRail('email', emailOk);
  updateRail('password', passwordOk);
  updateRail('confirmPassword', confirmOk);

  const isFormValid = nameOk && emailOk && passwordOk && confirmOk;
  if (!isFormValid) return;

  // Lock the button so a double-click can't fire two signups
  submitBtn.disabled = true;
  submitBtn.textContent = 'Creating account…';

  try {
    // Matches the Express route: userRouter.post("/signup", userSignup)
    // mounted at app.use("/users", userRouter) -> POST /users/signup
    const response = await fetch('http://localhost:3001/api/users/signup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: nameInput.value.trim(),
        email: emailInput.value.trim(),
        password: passwordInput.value
        // confirmPassword is intentionally NOT sent — it's a frontend-only check
      })
    });

    const data = await response.json();

    if (response.ok) {
      // 201 from userSignup: { newUser: { id, name, email }, msg }
      const firstName = (data.newUser && data.newUser.name ? data.newUser.name : nameInput.value.trim()).split(' ')[0];
      document.getElementById('successCopy').textContent =
        'Welcome, ' + firstName + ' — your workspace is ready.';
      form.style.display = 'none';
      successState.style.display = 'block';


      //  window.location.href = "/home"; 
    } else {
      // 400 (missing fields) or 500 (server/db error) from userSignup
      showServerError(data.msg || 'Something went wrong. Please try again.');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create account';
    }
  } catch (err) {
    // Network failure — server unreachable, CORS, offline, etc.
    showServerError('Could not reach the server. Check your connection and try again.');
    submitBtn.disabled = false;
    submitBtn.textContent = 'Create account';
  }
});
</script>

</body>
</html>
