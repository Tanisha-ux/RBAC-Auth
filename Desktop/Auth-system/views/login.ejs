<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Log in — Ledgerly</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/login.css">
</head>
<body>

<div class="shell">

  <!-- ============================ -->
  <!-- LEFT: brand panel (same as signup, different copy) -->
  <!-- ============================ -->
  <div class="brand-panel">
    <div class="brand-mark"><span class="dot"></span> Ledgerly</div>

    <div class="brand-copy">
      <h1>Good to see you <em>again.</em></h1>
      <p>Pick up right where you left off. Your books, your team, your numbers — exactly as you left them.</p>
    </div>

    <!--
      No progress rail here — login is a 2-field form with no
      multi-step feel, so the rail (which belongs to signup) is
      intentionally left out rather than faked with 2 empty steps.
    -->
  </div>

  <!-- ============================ -->
  <!-- RIGHT: form panel             -->
  <!-- ============================ -->
  <div class="form-panel">
    <div class="form-wrap">

      <!--
        Real server-rendered form: this backend calls res.render("login", { error })
        on bad credentials and res.redirect("/") on success — there is no JSON API
        to call here, so this is a plain HTML form POST, not a fetch() call.
      -->
      <form id="loginForm" >
        <div class="eyebrow">Welcome back</div>
        <h2>Log in to your workspace</h2>
        <p class="lede">New to Ledgerly? <a href="https://rbac-auth-8oc9.onrender.com/signup">Create an account.</a></p>

        <!--
          Server-rendered error banner. EJS fills this in directly from
          the `error` value passed by userLogin's res.render("login", { error }).
          Shown immediately on page load when present — no JS needed for this part.
        -->
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="form-error-banner" style="display:block;"><%= error %></div>
        <% } %>

        <!-- Email field -->
        <div class="field" id="emailField">
          <input type="text" id="email" name="email" placeholder="Email address" autocomplete="email" />
          <label for="email">Email address</label>
          <svg class="status-icon icon-valid" viewBox="0 0 18 18" fill="none"><path d="M3 9.5L7 13L15 5" stroke="#4E8B6B" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <svg class="status-icon icon-invalid" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7.3" stroke="#C04A3F" stroke-width="1.4"/><path d="M9 5.5V9.8" stroke="#C04A3F" stroke-width="1.4" stroke-linecap="round"/><circle cx="9" cy="12.4" r="0.9" fill="#C04A3F"/></svg>
          <div class="error-text" id="emailError"></div>
        </div>

        <!-- Password field -->
        <div class="field has-toggle" id="passwordField">
          <input type="password" id="password" name="password" placeholder="Password" autocomplete="current-password" />
          <label for="password">Password</label>
          <button type="button" class="toggle-visibility" id="togglePassword" aria-label="Show password">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M1.5 10S4.5 4 10 4s8.5 6 8.5 6-3 6-8.5 6-8.5-6-8.5-6Z" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="10" r="2.4" stroke="currentColor" stroke-width="1.4"/></svg>
          </button>
          <div class="error-text" id="passwordError"></div>
        </div>

        <div class="lede" style="margin-bottom: 18px; margin-top: -10px;">
          <a href="/forgot-password" style="border-bottom: 1px solid var(--accent);">Forgot your password?</a>
        </div>

        <button type="submit" class="submit-btn" id="submitBtn">Log in</button>

        <p class="fine-print">By continuing you agree to Ledgerly's <a href="#">Terms</a> and <a href="#">Privacy Policy</a>.</p>
      </form>

    </div>
  </div>

</div>

<script>
/* ============================================================ */
/* login.ejs — inline script                                     */
/* This is a real server-rendered form (action="/users/login"),  */
/* so JS here ONLY handles client-side UX:                       */
/*   - basic "don't submit empty fields" validation              */
/*   - floating label / password visibility (handled by CSS +    */
/*     the toggle button below)                                  */
/* The actual auth check, redirect, and error message all come   */
/* from the Express backend — JS never intercepts this submit.   */
/* ============================================================ */

const loginForm = document.getElementById('loginForm');
const emailInput = document.getElementById('email');
const passwordInput = document.getElementById('password');
const emailField = document.getElementById('emailField');
const passwordField = document.getElementById('passwordField');
const emailError = document.getElementById('emailError');
const passwordError = document.getElementById('passwordError');
const submitBtn = document.getElementById('submitBtn');


function showServerError(message) {
  let el = document.querySelector(".form-error-banner");

  if (!el) {
    el = document.createElement("div");
    el.className = "form-error-banner";
    document.querySelector(".form-wrap").prepend(el);
  }

  el.textContent = message;
  el.style.display = "block";
}

function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

function markValid(field, errorEl) {
  field.classList.remove('is-invalid');
  field.classList.add('is-valid');
  errorEl.textContent = '';
}

function markInvalid(field, errorEl, message) {
  field.classList.remove('is-valid');
  field.classList.add('is-invalid');
  errorEl.textContent = message;
}

// Light live feedback only — no "required field" nagging until submit
emailInput.addEventListener('input', function () {
  const value = emailInput.value.trim();
  if (value === '') {
    emailField.classList.remove('is-valid', 'is-invalid');
    emailError.textContent = '';
  } else if (!isValidEmail(value)) {
    markInvalid(emailField, emailError, 'That email address looks incomplete.');
  } else {
    markValid(emailField, emailError);
  }
});

passwordInput.addEventListener('input', function () {
  if (passwordInput.value === '') {
    passwordField.classList.remove('is-valid', 'is-invalid');
    passwordError.textContent = '';
  } else {
    markValid(passwordField, passwordError);
  }
});

// Show / hide password
document.getElementById('togglePassword').addEventListener('click', function () {
  const isPassword = passwordInput.type === 'password';
  passwordInput.type = isPassword ? 'text' : 'password';
  this.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
});


loginForm.addEventListener("submit", async (e) => {
  e.preventDefault();

  submitBtn.disabled = true;
  submitBtn.textContent = "Logging in...";

  try {
    const res = await fetch("http://localhost:3001/api/users/login", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        email: emailInput.value.trim(),
        password: passwordInput.value
      })
    });

    const data = await res.json();

    if (res.ok) {
      
      // window.location.href = "/home";
      localStorage.setItem("role", data.user.role);
      if (data.user.role === "admin") {
    window.location.href = "/admin";
  

    } 
    else{
      window.location.href = "/home";
    }
  }
  else {
      
      showServerError(data.msg || "Invalid credentials");
      submitBtn.disabled = false;
      submitBtn.textContent = "Log in";
      
      
    }
  } catch (err) {
    showServerError("Server not reachable");
    submitBtn.disabled = false;
    submitBtn.textContent = "Log in";
  }
});
</script>

</body>
</html>
